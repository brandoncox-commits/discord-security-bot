# --- Bams Modmin Tools configuration ---------------------------------------
# Copy this file to ".env" and fill in the values. Never commit your real .env.

# REQUIRED: your bot token from the Discord Developer Portal
#   https://discord.com/developers/applications  ->  Your App  ->  Bot  ->  Token
BOT_TOKEN=your-bot-token-here

# OPTIONAL: a fixed mod-log channel ID. For a PUBLIC bot installed in many
# servers this is usually left blank — the bot automatically logs to a channel
# named "mod-logs" in whichever server the command was run. Only set this if you
# run the bot for a single server and want to pin logging to one specific channel.
MOD_LOG_CHANNEL_ID=

# OPTIONAL: a guild (server) ID to sync slash commands to instantly. Handy while
# testing, because global command sync can take up to ~1 hour to appear the first
# time. Leave BLANK for a public bot so commands sync globally to every server.
DEV_GUILD_ID=
