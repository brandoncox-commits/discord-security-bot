# --- Bams Modmin Tools configuration ---------------------------------------
# Copy this file to ".env" and fill in the values. Never commit your real .env.

# REQUIRED: your bot token from the Discord Developer Portal
#   https://discord.com/developers/applications  ->  Your App  ->  Bot  ->  Token
BOT_TOKEN=your-bot-token-here

# OPTIONAL: a fixed mod-log channel ID. For a PUBLIC bot installed in many
# servers this is usually left blank — the bot automatically logs to a channel
# named "mod-logs" in whichever server the command was run. Only set this if you
# run the bot for a single server and want to pin logging to one specific channel.
MOD_LOG_CHANNEL_ID=

# OPTIONAL: a guild (server) ID to sync slash commands to instantly. Handy while
# testing, because global command sync can take up to ~1 hour to appear the first
# time. Leave BLANK for a public bot so commands sync globally to every server.
DEV_GUILD_ID=

# ---------------------------------------------------------------------------
# Twitch integration (Phase 2) — ALL OPTIONAL
# ---------------------------------------------------------------------------
# If ALL five vars below are set AND twitchio is installed, the bot will connect
# to Twitch IRC and award Discord XP for chat messages from linked members.
# If any var is missing the bot starts normally in Discord-only mode.
#
# How to get these values:
#   1. Go to https://dev.twitch.tv/console and register an application.
#      Set the OAuth redirect URL to http://localhost (or any valid URL).
#   2. Copy the Client ID and generate a Client Secret from that app page.
#   3. Generate a bot user access token + refresh token with the scopes:
#        chat:read  chat:edit
#      Use the Twitch Token Generator (https://twitchtokengenerator.com) or
#      the OAuth authorization code flow with your registered app.
#   4. TWITCH_BOT_USERNAME is the Twitch login name of the bot account (the
#      account whose token you generated in step 3).

# Your Twitch application's Client ID (from dev.twitch.tv/console)
TWITCH_CLIENT_ID=

# Your Twitch application's Client Secret
TWITCH_CLIENT_SECRET=

# The Twitch login name (username) of the bot/account that joins chat
TWITCH_BOT_USERNAME=

# OAuth user access token for the bot account (with chat:read, chat:edit)
# This token is used to authenticate to Twitch IRC.
TWITCH_BOT_ACCESS_TOKEN=

# OAuth refresh token for the bot account (used to auto-refresh the access token)
TWITCH_BOT_REFRESH_TOKEN=
